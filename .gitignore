# ── KiCad generated / temp files ─────────────────────────────────────────────
*-backups/
#auto_saved_files#/
_autosave-*
*.lck
~*
fp-info-cache
*.bak
*.kicad_sch-bak
*.kicad_pcb-bak

# Scratch / one-off files at root
untitled.kicad_sch

# Gerber working export folder (clean copy lives in hardware/kicad/gerbers/)
hardware/kicad/borh/

# ── ML model weights (large binaries — store separately) ─────────────────────
*.pt
*.onnx
*.tflite
*.task          # MediaPipe hand_landmarker (auto-downloaded on first run)
*.pkl           # trained ASL classifier (regenerate via asl_from_dataset.py)

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
asl_data.csv    # generated training data dump

# ── PlatformIO build output ───────────────────────────────────────────────────
.pio/
firmware/esp32/.vscode/.browse.c_cpp.db*
firmware/esp32/.vscode/c_cpp_properties.json
firmware/esp32/.vscode/launch.json
firmware/esp32/.vscode/ipch

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
